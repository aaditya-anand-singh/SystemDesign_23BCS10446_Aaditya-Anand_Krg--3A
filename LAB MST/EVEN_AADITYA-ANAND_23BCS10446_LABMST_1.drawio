        <mxCell id="kyS9uzmT_hkbeGxn3BXE-176" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;AADITYA ANAND&lt;br&gt;23BCS10446&lt;br&gt;23BCS_KRG_3A&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;Design a YouTube-like Video Sharing Platform with the following services:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ol&gt;&lt;li&gt;FUNCTIONAL REQUIREMENTS&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;User Login Service&lt;/li&gt;&lt;li&gt;Video Upload Service&lt;/li&gt;&lt;li&gt;Video Streaming Service&lt;/li&gt;&lt;li&gt;Recommendation Service&lt;/li&gt;&lt;li&gt;Comment &amp;amp; Engagement Service&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 2. NON-FUNCTIONAL REQUIREMENTS&lt;br&gt;&lt;ul&gt;&lt;li&gt;Scalability&lt;/li&gt;&lt;li&gt;Availability &amp;gt;&amp;gt;&amp;gt; Consistency&lt;/li&gt;&lt;li&gt;Latency ~ 50ms&lt;/li&gt;&lt;li&gt;Scaling&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1190" width="485" x="520" y="-800" as="geometry" />
        </mxCell>
        <mxCell id="kyS9uzmT_hkbeGxn3BXE-178" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Implement a mechanism to detect and restrict copyrighted or policy-violating content uploads.&lt;/div&gt;&lt;div&gt;Optimize the personalized video recommendation feed for millions of users.&lt;/div&gt;&lt;div&gt;Highlight where a Back-Fill service can be used in the architecture.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="820" x="1144" y="-360" as="geometry" />
        </mxCell>
        <mxCell id="kyS9uzmT_hkbeGxn3BXE-181" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;br&gt;&lt;h3 data-section-id=&quot;v30wu4&quot; data-start=&quot;0&quot; data-end=&quot;54&quot;&gt;Detect &amp;amp; Restrict Copyright / Policy Violations&lt;/h3&gt;&lt;ul data-start=&quot;55&quot; data-end=&quot;389&quot;&gt;&lt;li data-section-id=&quot;19651cg&quot; data-start=&quot;55&quot; data-end=&quot;98&quot;&gt;&lt;p data-start=&quot;57&quot; data-end=&quot;98&quot;&gt;User uploads video → &lt;strong data-start=&quot;78&quot; data-end=&quot;97&quot;&gt;Content Service&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1hie6hs&quot; data-start=&quot;99&quot; data-end=&quot;157&quot;&gt;&lt;p data-start=&quot;101&quot; data-end=&quot;157&quot;&gt;Event sent to &lt;strong data-start=&quot;115&quot; data-end=&quot;156&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;Apache Kafka&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;u2chu7&quot; data-start=&quot;158&quot; data-end=&quot;265&quot;&gt;&lt;p data-start=&quot;160&quot; data-end=&quot;189&quot;&gt;&lt;strong data-start=&quot;160&quot; data-end=&quot;181&quot;&gt;Moderator Service&lt;/strong&gt; checks:&lt;/p&gt;&lt;ul data-start=&quot;192&quot; data-end=&quot;265&quot;&gt;&lt;li data-section-id=&quot;7lf4ot&quot; data-start=&quot;192&quot; data-end=&quot;226&quot;&gt;&lt;p data-start=&quot;194&quot; data-end=&quot;226&quot;&gt;copyright (video fingerprinting)&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;6vl81d&quot; data-start=&quot;229&quot; data-end=&quot;265&quot;&gt;&lt;p data-start=&quot;231&quot; data-end=&quot;265&quot;&gt;policy violations (AI moderation).&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-section-id=&quot;j2gyqn&quot; data-start=&quot;266&quot; data-end=&quot;389&quot;&gt;&lt;p data-start=&quot;268&quot; data-end=&quot;275&quot;&gt;Result:&lt;/p&gt;&lt;ul data-start=&quot;278&quot; data-end=&quot;389&quot;&gt;&lt;li data-section-id=&quot;wc5dql&quot; data-start=&quot;278&quot; data-end=&quot;320&quot;&gt;&lt;p data-start=&quot;280&quot; data-end=&quot;320&quot;&gt;&lt;strong data-start=&quot;280&quot; data-end=&quot;296&quot;&gt;blocked_post&lt;/strong&gt; → reject + notify user.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1jbk59l&quot; data-start=&quot;323&quot; data-end=&quot;389&quot;&gt;&lt;p data-start=&quot;325&quot; data-end=&quot;389&quot;&gt;&lt;strong data-start=&quot;325&quot; data-end=&quot;342&quot;&gt;filtered_post&lt;/strong&gt; → allowed → stored in &lt;strong data-start=&quot;365&quot; data-end=&quot;388&quot;&gt;Object Storage (S3)&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="1090" x="1180" y="-340" as="geometry" />
        </mxCell>
        <mxCell id="kyS9uzmT_hkbeGxn3BXE-182" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;br&gt;&lt;h3 data-section-id=&quot;1fxf69z&quot; data-start=&quot;396&quot; data-end=&quot;446&quot;&gt;Optimizing Personalized Recommendation Feed&lt;/h3&gt;&lt;ul data-start=&quot;447&quot; data-end=&quot;750&quot;&gt;&lt;li data-section-id=&quot;1ecmzis&quot; data-start=&quot;447&quot; data-end=&quot;507&quot;&gt;&lt;p data-start=&quot;449&quot; data-end=&quot;507&quot;&gt;User actions (likes, watch time, comments) → Kafka events.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;r4ibkx&quot; data-start=&quot;508&quot; data-end=&quot;571&quot;&gt;&lt;p data-start=&quot;510&quot; data-end=&quot;571&quot;&gt;&lt;strong data-start=&quot;510&quot; data-end=&quot;536&quot;&gt;Recommendation Service&lt;/strong&gt; processes events using ML ranking.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;3e0fag&quot; data-start=&quot;572&quot; data-end=&quot;622&quot;&gt;&lt;p data-start=&quot;574&quot; data-end=&quot;622&quot;&gt;Results stored in &lt;strong data-start=&quot;592&quot; data-end=&quot;621&quot;&gt;cache + recommendation DB&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;senbxw&quot; data-start=&quot;623&quot; data-end=&quot;689&quot;&gt;&lt;p data-start=&quot;625&quot; data-end=&quot;689&quot;&gt;&lt;strong data-start=&quot;625&quot; data-end=&quot;643&quot;&gt;Fanout service&lt;/strong&gt; distributes recommended videos to user feeds.&lt;/p&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1crjdqg&quot; data-start=&quot;690&quot; data-end=&quot;750&quot;&gt;&lt;p data-start=&quot;692&quot; data-end=&quot;750&quot;&gt;Cache ensures &lt;strong data-start=&quot;706&quot; data-end=&quot;749&quot;&gt;fast feed loading for millions of users&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="30" width="600" x="1497.02" y="-210" as="geometry" />
